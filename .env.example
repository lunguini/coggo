# Coggo runtime environment.
#
# Copy this file to .env (same directory) and fill in the values.
# `export` prefixes mean you can `source .env` directly with no
# `set -a` dance — both the laptop and the phone do exactly that.
#
#   cp .env.example .env
#   chmod 600 .env
#   <edit .env>
#   source .env       # makes everything available in your shell
#
# .env is gitignored. .env.example is the committed reference.

# === Coggo bearer token =====================================================
# Mint with:
#   coggo token create --all --label <where-this-is-used>
# Examples:
#   --label claude-ai-mobile     for the OAuth gateway (--all required)
#   --label claude-code-laptop   for direct bearer use
export COGGO_TOKEN=

# === Google OAuth (gateway only) ============================================
# OAuth client (Web application) from console.cloud.google.com.
# Authorized redirect URI in Google Cloud must be:
#   $GATEWAY_PUBLIC_URL/oauth/callback
export GOOGLE_CLIENT_ID=
export GOOGLE_CLIENT_SECRET=

# Public URL the gateway is reachable at. Two ways to set this up:
#   1. Tailscale Funnel + stable hostname: https://coggo.<your-tailnet>.ts.net
#      (recommended for zero-config; uses `tailscale set --hostname=coggo`).
#   2. Cloudflare Tunnel on your own domain: https://coggo.example.com
#      (set CLOUDFLARE_TUNNEL_NAME below; see docs/cloudflare-tunnel.md).
# Whichever you choose, this URL must match the OAuth redirect registered in
# Google Cloud (i.e. $GATEWAY_PUBLIC_URL/oauth/callback).
export GATEWAY_PUBLIC_URL=

# === Email allowlist (gateway only) =========================================
# FAIL-CLOSED. Comma-separated list of Google account emails permitted to
# call /mcp. If empty, EVERY request is rejected — Funnel is a public
# surface, so this is the safety net. Set this before exposing the gateway.
export OAUTH_ALLOWED_EMAILS=

# === Optional gateway tuning ================================================
# Domains allowed as client redirect_uri values (in addition to localhost).
# Default: claude.ai,claude.com. Add chatgpt.com,openai.com if you wire up
# ChatGPT custom connectors.
# export OAUTH_ALLOWED_CLIENT_DOMAINS=claude.ai,claude.com

# Rate limits. Defaults are sane; tune if you see 429s in normal use.
# Global token-bucket fronts every gateway endpoint (Funnel collapses public
# clients onto one relay IP, so per-IP limiting is meaningless — the global
# cap is the right shape).
# export RATE_GLOBAL_RPS=50
# export RATE_GLOBAL_BURST=100
# Per-authenticated-email bucket on /mcp, applied after token validation so
# legitimate users get separate quotas.
# export RATE_PER_EMAIL_RPM=10
# export RATE_PER_EMAIL_BURST=30

# Logging + binding (rarely changed).
# export COGGO_LOG_LEVEL=info
# export GATEWAY_LISTEN=:8080
# export COGGO_UPSTREAM=http://localhost:6177

# === Litestream replication to Cloudflare R2 ================================
# Optional but recommended. All four R2_* values must be filled in to enable
# replication; if any is blank the boot launcher skips litestream cleanly
# (coggo + gateway still come up). See docs/backup.md for R2 setup.
#
# COGGO_DB_PATH must be absolute (Litestream doesn't expand ~).
#   Laptop:  /Users/<you>/.local/share/coggo/coggo.db
#   Phone:   /data/data/com.termux/files/home/.local/share/coggo/coggo.db
export COGGO_DB_PATH=$HOME/.local/share/coggo/coggo.db

export R2_ACCOUNT_ID=
export R2_BUCKET=coggo-replica
export R2_ACCESS_KEY_ID=
export R2_SECRET_ACCESS_KEY=

# === Cloudflare Tunnel (optional) ===========================================
# Set this to expose the gateway on a custom domain (e.g. coggo.example.com)
# via cloudflared instead of Tailscale Funnel. When set, the boot launcher
# starts `cloudflared tunnel run $CLOUDFLARE_TUNNEL_NAME` and skips Funnel.
# Tailscale itself stays up so SSH keeps working.
#
# One-time setup (see docs/cloudflare-tunnel.md):
#   cloudflared tunnel login
#   cloudflared tunnel create coggo
#   cloudflared tunnel route dns coggo coggo.<your-domain>
#   # write ~/.cloudflared/config.yml pointing ingress at localhost:$GATEWAY_PORT
#
# Leave blank to use Tailscale Funnel.
# export CLOUDFLARE_TUNNEL_NAME=coggo
